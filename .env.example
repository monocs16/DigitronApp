# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these values at: supabase.com → your project → Project Settings → API

# Client (Vite exposes VITE_* to the browser — use the anon / publishable key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server (TanStack server functions / SSR — never prefix secrets with VITE_)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
